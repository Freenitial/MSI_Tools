$searchLabel_DetectedProps     = gen $panelFilter_DetectedProps "Label"   "Filter:" 'Dock=Left' 'Autosize=$true'
$searchTextBox_DetectedProps.Add_KeyDown({
    if ($_.KeyCode -eq [System.Windows.Forms.Keys]::Enter) {
        $filterText = $searchTextBox_DetectedProps.Text.Trim()
        if ($filterText -eq "Press ENTER to search") { $filterText = "" }
        $form.Cursor = [System.Windows.Forms.Cursors]::WaitCursor
        [System.Windows.Forms.Application]::DoEvents()
        $detectedPropsOuterPanel.SuspendLayout()
        $detectedPropsScrollPanel.SuspendLayout()
        $detectedPropsFlowPanel.SuspendLayout()
        foreach ($propPanel in $detectedPropsFlowPanel.Controls) {
            if ($propPanel -isnot [System.Windows.Forms.FlowLayoutPanel]) { continue }
            if ([string]::IsNullOrEmpty($filterText)) { $propPanel.Visible = $true; continue }
            $matchFound = $false
            foreach ($ctrl in $propPanel.Controls) {
                if ($ctrl -is [System.Windows.Forms.Label] -and $ctrl.Text -like "*$filterText*") { $matchFound = $true; break }
                if ($ctrl -is [System.Windows.Forms.FlowLayoutPanel]) {
                    foreach ($wrapper in $ctrl.Controls) {
                        foreach ($inner in $wrapper.Controls) {
                            if ($inner -is [System.Windows.Forms.Button] -and ($inner.Text -like "*$filterText*" -or $inner.Tag -like "*$filterText*")) { $matchFound = $true; break }
                        }
                        if ($matchFound) { break }
                    }
                }
                if ($matchFound) { break }
            }
            $propPanel.Visible = $matchFound
        }
        $detectedPropsFlowPanel.ResumeLayout()
        $detectedPropsScrollPanel.ResumeLayout()
        $detectedPropsOuterPanel.ResumeLayout()
        $form.Cursor = [System.Windows.Forms.Cursors]::Default
    }
})

