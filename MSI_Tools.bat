$button_ConnectionStatus.Add_Click({
    $results = $this.Tag
    if (-not $results -or $results.Count -eq 0) { return }
    $credential = Get-CredentialFromPanel
    $dialogResult = Show-ComputersDialog -Results $results -Credential $credential
