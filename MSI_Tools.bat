# Function that quick-create majority of controls
function New-Control {
    param(
        [Parameter(Mandatory=$false)][AllowNull()]     $container,
        [Parameter(Mandatory=$true)][string]           $type,
        [Parameter(ValueFromRemainingArguments=$true)] $args
