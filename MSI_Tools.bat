function Update-RegistryListViewFilter {
    if ($null -eq $script:RegistryCache -or $script:RegistryCache.Count -eq 0) { return }
    $filterTerms = @()
    if ($searchTextBox_Tab3.Tag -is [hashtable] -and -not $searchTextBox_Tab3.Tag.IsPlaceholder) {
        $filterTerms = @($searchTextBox_Tab3.Text -split ';' | ForEach-Object { $_.Trim().ToLower() } | Where-Object { $_ -ne '' })
    }
    $hasTextFilter = ($filterTerms.Count -gt 0)
    $filteredCache = [System.Collections.ArrayList]::new()
    foreach ($entry in $script:RegistryCache) {
        $path = $entry.RegistryPath
        $includeByHive = $false
        if ($path.StartsWith("HKLM:", [System.StringComparison]::OrdinalIgnoreCase)) {
            if ($checkbox_HKLM64.Checked -and $path -like "HKLM:Software\Microsoft\Windows\CurrentVersion\Uninstall\*" -and $path -notlike "*Wow6432Node*") {
                $includeByHive = $true
            }
            elseif ($checkbox_HKLM32.Checked -and $path -like "HKLM:Software\Wow6432Node\Microsoft\Windows\CurrentVersion\Uninstall\*") {
                $includeByHive = $true
            }
        }
        elseif ($path.StartsWith("HKCU:", [System.StringComparison]::OrdinalIgnoreCase)) {
            if ($checkbox_HKCU64.Checked -and $path -like "HKCU:Software\Microsoft\Windows\CurrentVersion\Uninstall\*" -and $path -notlike "*Wow6432Node*") {
                $includeByHive = $true
            }
            elseif ($checkbox_HKCU32.Checked -and $path -like "HKCU:Software\Wow6432Node\Microsoft\Windows\CurrentVersion\Uninstall\*") {
                $includeByHive = $true
            }
        }
        elseif ($path.StartsWith("HKU:", [System.StringComparison]::OrdinalIgnoreCase)) {
            if ($checkbox_HKCU64.Checked -and $path -like "HKU:*\Software\Microsoft\Windows\CurrentVersion\Uninstall\*" -and $path -notlike "*Wow6432Node*") {
                $includeByHive = $true
            }
            elseif ($checkbox_HKCU32.Checked -and $path -like "HKU:*\Software\Wow6432Node\Microsoft\Windows\CurrentVersion\Uninstall\*") {
                $includeByHive = $true
            }
        }
        if (-not $includeByHive) { continue }
        if ($hasTextFilter) {
            $matchText = $false
            $fieldsToCheck = @(
                $entry.DisplayName, $entry.ProductCode, $entry.UninstallString,
                $entry.QuietUninstallString,
                $entry.DisplayVersion, $entry.InstallDate, $entry.InstallSource,
                $entry.FormattedPath, $entry.Device
            )
            foreach ($term in $filterTerms) {
                if ($matchText) { break }
                foreach ($field in $fieldsToCheck) {
                    if ($field -and $field.ToLower().Contains($term)) { $matchText = $true ; break }
                }
            }
            if (-not $matchText) { continue }
        }
        [void]$filteredCache.Add($entry)
    }
    $showDevice = $false
    for ($i = 0; $i -lt $listView_Registry.Columns.Count; $i++) {
        if ($listView_Registry.Columns[$i].Text -eq "Device") { $showDevice = $true; break }
    }
    update-RegistryListViewFromCache `
        -listViewparam $listView_Registry `
        -allListViewItems $allListViewItems_Registry `
        -ShowDevice $showDevice `
        -ShowInstallSource $checkbox_ShowInstallSource.Checked `
        -UseQuietUninstall $checkbox_QuietUninstallIfAvailable.Checked `
        -SourceData $filteredCache
    AdjustListViewColumns -listView $listView_Registry
}

function Invoke-RegeditShowButton {
    param([string]$RegistryPath, [System.Windows.Forms.Control]$SourceButton)
    $targetComputers = Get-TargetComputersFromPanel
    $hasRemote = ($targetComputers.Count -gt 0 -and -not [string]::IsNullOrWhiteSpace($targetComputers[0]))
    # No remote targets → open locally
    if (-not $hasRemote) {
        Open-RegeditHere -Path $RegistryPath
        return
    }
    # ── Scriptblock to open regedit on a specific remote computer ──
    $openRemote = {
        param([string]$ComputerName, [string]$Path)
        $credential = Get-CredentialFromPanel
        $form.Cursor = [System.Windows.Forms.Cursors]::WaitCursor
        [System.Windows.Forms.Application]::DoEvents()
        try {
            # Test connection on-demand if not already cached as successful
            $cachedResult = $script:RemoteConnectionResults | Where-Object { $_.Computer -eq $ComputerName -and $_.Success } | Select-Object -First 1
            if (-not $cachedResult) {
                $previousResults = if ($script:RemoteConnectionResults) { @($script:RemoteConnectionResults) } else { @() }
                $newResults      = @(Test-RemoteConnections -Computers @($ComputerName) -Credential $credential)
                $mergedResults   = [System.Collections.ArrayList]::new()
                foreach ($prev in $previousResults) {
                    if ($prev.Computer -ne $ComputerName) { [void]$mergedResults.Add($prev) }
                }
                foreach ($nr in $newResults) { [void]$mergedResults.Add($nr) }
                $script:RemoteConnectionResults = $mergedResults
                Update-ConnectionStatusDisplay -Results @($mergedResults) -Credential $credential
                $cachedResult = $newResults | Where-Object { $_.Computer -eq $ComputerName -and $_.Success } | Select-Object -First 1
                if (-not $cachedResult) {
                    [System.Windows.Forms.MessageBox]::Show(
                        "Unable to connect to $ComputerName.",
                        "Connection Failed",
                        [System.Windows.Forms.MessageBoxButtons]::OK,
                        [System.Windows.Forms.MessageBoxIcon]::Warning)
                    return
                }
            }
            $effectivePath = $Path
            if ($Path -match '^HKCU') {
                $sid = $cachedResult.ConsoleUserSID
                if (-not $sid) {
                    $userInfo = Get-RemoteConsoleUser -ComputerName $ComputerName -Credential $credential
                    $sid = $userInfo.SID
                }
                if (-not $sid) {
                    [System.Windows.Forms.MessageBox]::Show(
                        "No logged-on user found on $ComputerName.`nCannot access HKCU hive remotely without an active user session.",
                        "No User Session",
                        [System.Windows.Forms.MessageBoxButtons]::OK,
                        [System.Windows.Forms.MessageBoxIcon]::Warning)
                    return
                }
                $effectivePath = $Path -replace '^HKCU\\', "HKU\$sid\"
            }
            Open-RegeditHere -Path $effectivePath -ComputerName $ComputerName
        }
        finally { $form.Cursor = [System.Windows.Forms.Cursors]::Default }
    }
    # ── Build dropdown menu ──
    $dropdownMenu = [System.Windows.Forms.ContextMenuStrip]::new()
    # Local computer entry
    $localMenuItem     = [System.Windows.Forms.ToolStripMenuItem]::new("$env:COMPUTERNAME (local)")
    $localMenuItem.Tag = $RegistryPath
    $localMenuItem.Add_Click({ Open-RegeditHere -Path $this.Tag })
    [void]$dropdownMenu.Items.Add($localMenuItem)
    # Remote computer entries (use cached display name if available, raw name otherwise)
    foreach ($computer in $targetComputers) {
        $cached       = $script:RemoteConnectionResults | Where-Object { $_.Computer -eq $computer -and $_.Success } | Select-Object -First 1
        $displayName  = if ($cached) { Get-ComputerDisplayName -Computer $computer } else { $computer }
        $menuItem     = [System.Windows.Forms.ToolStripMenuItem]::new($displayName)
        $menuItem.Tag = @{ Computer = $computer; Path = $RegistryPath; Action = $openRemote }
        $menuItem.Add_Click({ & $this.Tag.Action $this.Tag.Computer $this.Tag.Path })
        [void]$dropdownMenu.Items.Add($menuItem)
    }
    $dropdownMenu.Show($SourceButton, [System.Drawing.Point]::new(0, $SourceButton.Height))
}

