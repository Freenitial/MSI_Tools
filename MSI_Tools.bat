function Resolve-BooleanCapitalization {
    param([string]$DefaultValue, [string]$OptionValue)
    # Boolean pair map preserving capitalization style of the default
    $pairs = [System.Collections.Hashtable]::new([System.StringComparer]::Ordinal)
    $pairs.Add('YES','NO');     $pairs.Add('NO','YES')
    $pairs.Add('Yes','No');     $pairs.Add('No','Yes')
    $pairs.Add('yes','no');     $pairs.Add('no','yes')
    $pairs.Add('TRUE','FALSE'); $pairs.Add('FALSE','TRUE')
    $pairs.Add('True','False'); $pairs.Add('False','True')
    $pairs.Add('true','false'); $pairs.Add('false','true')
    if (-not $pairs.ContainsKey($DefaultValue)) { return $OptionValue }
    $expectedOpposite = $pairs[$DefaultValue]
    if ($OptionValue -ieq $expectedOpposite) { return $expectedOpposite }
    return $OptionValue
}

