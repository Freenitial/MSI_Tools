            $this.Text = ""
            $clip = [System.Windows.Forms.Clipboard]::GetText()
            foreach ($ch in $clip.ToCharArray()) { $script:SecurePassword.AppendChar($ch) }
            $this.AppendText([string]::new([char]0x25CF, $clip.Length))
