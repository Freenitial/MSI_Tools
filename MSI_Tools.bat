function Show-NonBlockingMessage {
    param([string]$message, [string]$title = "Information", [int]$timeout = 0)
    # Form setup with DPI scaling
    $successForm = gen $null "Form" $title 'StartPosition=CenterScreen' 'TopMost=$true' 'MinimizeBox=$false' 'MaximizeBox=$false' 'ShowIcon=$false' 'FormBorderStyle=FixedDialog'
    $successForm.SuspendLayout()
    $successForm.Font                = New-Object System.Drawing.Font("Segoe UI", 9, [System.Drawing.FontStyle]::Regular, [System.Drawing.GraphicsUnit]::Point)
    $successForm.AutoScaleDimensions = New-Object System.Drawing.SizeF(96, 96)
    $successForm.AutoScaleMode       = [System.Windows.Forms.AutoScaleMode]::Dpi
    $successForm.ClientSize          = New-Object System.Drawing.Size(260, 100)
    # Label (Dock=Fill)
    $label = gen $successForm "Label" $message 'Dock=Fill' 'TextAlign=MiddleCenter' 'Font=Segoe UI, 12, Bold'
    # Button panel (Dock=Bottom)
    $buttonPanel = gen $successForm "FlowLayoutPanel" 'Dock=Bottom' 'AutoSize=$true' 'AutoSizeMode=GrowAndShrink' 'FlowDirection=LeftToRight' 'WrapContents=$false' 'Padding=0 0 0 5'
    $buttonPanel.Anchor = [System.Windows.Forms.AnchorStyles]::None
    $button = gen $buttonPanel "Button" "OK" 'AutoSize=$true'
    $button.Add_Click({ param($csender, $cargs) ($csender.FindForm()).Close() })
    # Center the button panel content
    $buttonPanel.Add_Layout({ $buttonPanel.Padding = New-Object System.Windows.Forms.Padding([int](($successForm.ClientSize.Width - $buttonPanel.PreferredSize.Width) / 2), 0, 0, 5) })
    $successForm.ResumeLayout()
    if ($timeout -gt 0) {
        $timer          = New-Object System.Windows.Forms.Timer
        $timer.Interval = $timeout * 1000
        $timer.Tag      = $successForm
        $timer.Add_Tick({ param($tsender, $targs) $tsender.Stop() ; ($tsender.Tag).Close() })
        $timer.Start()
    }
    $successForm.Show()
}

function ListExport {
    param(
        [Parameter(Mandatory=$false)]
        [System.Windows.Forms.ListView]$listView,
        [Parameter(Mandatory=$true)]
        [bool]$all
    )
    $itemsToExport = if ($all) { $listView.Items } else { $listView.SelectedItems }
    if ($itemsToExport.Count -eq 0) {
        [System.Windows.Forms.MessageBox]::Show("Nothing to export.", "Warning", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Warning) | Out-Null
        return
    }
    # Form setup with DPI scaling
    $formatForm = gen $null "Form" "Export" 'StartPosition=CenterScreen' 'MinimizeBox=$false' 'MaximizeBox=$false' 'ShowIcon=$false'
    $formatForm.SuspendLayout()
    $formatForm.Font                = New-Object System.Drawing.Font("Segoe UI", 9, [System.Drawing.FontStyle]::Regular, [System.Drawing.GraphicsUnit]::Point)
    $formatForm.AutoScaleDimensions = New-Object System.Drawing.SizeF(96, 96)
    $formatForm.AutoScaleMode       = [System.Windows.Forms.AutoScaleMode]::Dpi
    $formatForm.ClientSize          = New-Object System.Drawing.Size(280, 130)
    $formatForm.FormBorderStyle     = [System.Windows.Forms.FormBorderStyle]::FixedDialog
    # Progress bar (Dock=Bottom, hidden until export starts)
    $ExProgress = gen $formatForm "ProgressBar" 'Dock=Bottom' 'Style=Continuous' 'Minimum=0' 'Maximum=100' 'Value=0' 'Visible=$false'
    # Button panel (Dock=Bottom)
    $buttonPanel = gen $formatForm "FlowLayoutPanel" 'Dock=Bottom' 'AutoSize=$true' 'AutoSizeMode=GrowAndShrink' 'FlowDirection=LeftToRight' 'WrapContents=$false' 'Padding=5 3 5 3'
    $okButton     = gen $buttonPanel "Button" "Export" 'AutoSize=$true'
    $cancelButton = gen $buttonPanel "Button" "Cancel" 'AutoSize=$true'
    $cancelButton.Add_Click({ $formatForm.Close() })
    # Content panel (Dock=Fill)
    $contentPanel = gen $formatForm "FlowLayoutPanel" 'Dock=Fill' 'FlowDirection=TopDown' 'WrapContents=$false' 'Padding=7 7 7 0'
    $label    = gen $contentPanel "Label" "Choose an export format :" 'AutoSize=$true' 'Margin=0 0 0 3'
    # Options row
    $optionsFlow  = gen $contentPanel "FlowLayoutPanel" 'AutoSize=$true' 'AutoSizeMode=GrowAndShrink' 'FlowDirection=LeftToRight' 'WrapContents=$false' 'Margin=0'
    $comboBox     = gen $optionsFlow "ComboBox" 'DropDownStyle=DropDownList' 'Width=100' 'Margin=0 0 10 0'
    $comboBox.Items.AddRange(@("OGV Hybrid", "XLSX", "CSV"))
    $comboBox.SelectedIndex = 0
    $openafterbtn = gen $optionsFlow "CheckBox" "Open after export" 'AutoSize=$true' 'Margin=0 3 0 0'
    $formatForm.ResumeLayout()
    $okButton.Add_Click({
        $okButton.Enabled = $false
        $comboBox.Enabled = $false
        $columns = $listView.Columns
        $data = New-Object System.Collections.Generic.List[System.Object[]]
        foreach ($item in $itemsToExport) {
            $row = @($null) * $columns.Count
            foreach ($col in $columns) { $index = $col.Index ; if ($item.SubItems.Count -gt $index) { $row[$index] = $item.SubItems[$index].Text } else { $row[$index] = "" } }
            $data.Add($row)
        }
        $saveFileDialog = New-Object System.Windows.Forms.SaveFileDialog
        $dateTimeString = (Get-Date -Format "yyyy-MM-dd_HH-mm")
        switch ($comboBox.SelectedItem) {
            "OGV Hybrid"  { $saveFileDialog.Filter = "Batch (*.bat)|*.bat"  ; $saveFileDialog.FileName = "Export_MSI_$dateTimeString.bat" }
            "XLSX"        { $saveFileDialog.Filter = "Excel (*.xlsx)|*.xlsx"; $saveFileDialog.FileName = "Export_MSI_$dateTimeString.xlsx" }
            "CSV"         { $saveFileDialog.Filter = "CSV (*.csv)|*.csv"    ; $saveFileDialog.FileName = "Export_MSI_$dateTimeString.csv" }
        }
        $saveFileDialog.Title = "Select a path for export"
        $result = $saveFileDialog.ShowDialog()
        if ($result -ne [System.Windows.Forms.DialogResult]::OK) { $okButton.Enabled = $true ; $comboBox.Enabled = $true ; return }
        $filePath = $saveFileDialog.FileName
        $ExProgress.Visible = $true
        [System.Windows.Forms.Application]::DoEvents()
        $totalSteps = $data.Count
        $progressStep = [int](100 / $totalSteps)
        $currentProgress = 0
        switch ($comboBox.SelectedItem) {
            "OGV Hybrid" {
                $headers = $columns | ForEach-Object { $_.Text }
                $objects = New-Object System.Collections.ArrayList
                foreach ($row in $data) {
                    $obj = [ordered]@{}
                    for ($i = 0; $i -lt $headers.Count; $i++) { $obj[$headers[$i]] = $row[$i] }
                    $objects.Add([PSCustomObject]$obj) | Out-Null
                    $currentProgress += $progressStep
                    $ExProgress.Value = [int][math]::Min($currentProgress, 100)
                    [System.Windows.Forms.Application]::DoEvents()
                }
                $scriptContent = @"
<# ::
    cls & @echo off & title Export_MSI_$dateTimeString
    powershell -NoLogo -NoProfile -Ex Bypass -Window Hidden -Command "`$sb=[ScriptBlock]::Create([IO.File]::ReadAllText('%~f0'));&`$sb"
    exit /b
#>

`$jsonData = @'
$(($objects | ConvertTo-Json))
'@

`$data = ConvertFrom-Json -InputObject `$jsonData
`$data | Select-Object '$($headers -join "','")' | Out-GridView -Title 'Export_MSI_$dateTimeString' -Wait
"@
                [System.IO.File]::WriteAllLines($filePath, $scriptContent, [System.Text.Encoding]::UTF8)
            }
            "XLSX" {
                $headers   = $columns | ForEach-Object { $_.Text }
                $dataArray = $data.ToArray()
                Export-ToXlsx -Path $filePath -Sheets @(@{ Name = "Export"; Data = $dataArray; Columns = $headers }) -ProgressBar $ExProgress
            }
            "CSV" {
                $headers  = ($columns | ForEach-Object { $_.Text }) -join ";"
                $csvLines = New-Object System.Collections.Generic.List[string]
                $csvLines.Add($headers)
                foreach ($row in $data) { $csvLines.Add(($row -join ";")) ; $currentProgress += $progressStep ; $ExProgress.Value = [int][math]::Min($currentProgress, 100) ; [System.Windows.Forms.Application]::DoEvents() }
                [System.IO.File]::WriteAllLines($filePath, $csvLines)
            }
        }
        $ExProgress.Value = 100
        [System.Windows.Forms.Application]::DoEvents()
        if ($openafterbtn.Checked) { Start-Process -FilePath $filePath }
        $formatForm.Close()
        Show-NonBlockingMessage -message "Export Complete" -title "Success" -timeout 2
    })
    $formatForm.ShowDialog()
}

function Export-ToXlsx {
    <#
    .SYNOPSIS
        Exports one or more datasets to a single XLSX file with multiple sheets
    .PARAMETER Path
        Output file path
    .PARAMETER Sheets
        Array of hashtables with keys: Name (sheet name), Data (object array), Columns (optional)
    .PARAMETER ProgressBar
        Optional WinForms progress bar control
    #>
    [CmdletBinding()]
    param(
        [Parameter(Mandatory=$true)][string]$Path,
        [Parameter(Mandatory=$true)][hashtable[]]$Sheets,
        [Parameter(Mandatory=$false)]$ProgressBar
    )
    [void][Reflection.Assembly]::LoadWithPartialName("WindowsBase")
    [void][Reflection.Assembly]::LoadWithPartialName("System.Drawing")
    [void][Reflection.Assembly]::LoadWithPartialName("System.Windows.Forms")
    if ([System.IO.File]::Exists($Path)) { Remove-Item $Path }
    $Package = [System.IO.Packaging.Package]::Open($Path, [System.IO.FileMode]::Create, [System.IO.FileAccess]::ReadWrite)
    $Namespace = "http://schemas.openxmlformats.org/spreadsheetml/2006/main"
    $RelNamespace = "http://schemas.openxmlformats.org/officeDocument/2006/relationships"
    # GDI measurement objects for precise column width calculation
    $measureFont = New-Object System.Drawing.Font("Calibri", 11, [System.Drawing.FontStyle]::Regular, [System.Drawing.GraphicsUnit]::Point)
    $measureFontHeader = New-Object System.Drawing.Font("Calibri", 12, [System.Drawing.FontStyle]::Bold, [System.Drawing.GraphicsUnit]::Point)
    $measureBitmap = New-Object System.Drawing.Bitmap(1, 1)
    $measureGraphics = [System.Drawing.Graphics]::FromImage($measureBitmap)
    $maxSize = New-Object System.Drawing.Size([int]::MaxValue, [int]::MaxValue)
    $textFormatFlags = [System.Windows.Forms.TextFormatFlags]::NoPadding -bor [System.Windows.Forms.TextFormatFlags]::NoPrefix
    # Measure the reference digit "0" width using a 10-char sample to eliminate per-call overhead
    $digitZeroWidth = [System.Windows.Forms.TextRenderer]::MeasureText($measureGraphics, "0000000000", $measureFont, $maxSize, $textFormatFlags).Width / 10.0
    # Scriptblock to measure text width in column-width units using GDI (TextRenderer)
    $MeasureText = {
        param($Text, $Font)
        if ([string]::IsNullOrEmpty($Text)) { return 0 }
        $pixelWidth = [System.Windows.Forms.TextRenderer]::MeasureText($measureGraphics, $Text, $Font, $maxSize, $textFormatFlags).Width
        return ($pixelWidth / $digitZeroWidth)
    }
    # Scriptblock to create and append a cell element to a row
    $AddCell = {
        param($Doc, $ParentNode, $Namespace, $ColIndex, $RowIndex, $Value, $StyleIndex)
        if ($null -eq $Value) { $Value = "" }
        $Cell = $Doc.CreateElement("c", $Namespace)
        $Cell.SetAttribute("r", ([char](65 + $ColIndex - 1)) + [string]$RowIndex)
        $Cell.SetAttribute("t", "inlineStr")
        if ($StyleIndex) { $Cell.SetAttribute("s", [string]$StyleIndex) }
        $InlineStr = $Doc.CreateElement("is", $Namespace)
        $TextNode = $Doc.CreateElement("t", $Namespace)
        $TextNode.InnerText = $Value
        $InlineStr.AppendChild($TextNode) | Out-Null
        $Cell.AppendChild($InlineStr) | Out-Null
        $ParentNode.AppendChild($Cell) | Out-Null
    }
    # Build workbook with sheet references
    $sheetsXmlFragment = ""
    for ($sheetIndex = 0; $sheetIndex -lt $Sheets.Count; $sheetIndex++) {
        $sheetName = $Sheets[$sheetIndex].Name
        $rId = "rId$($sheetIndex + 1)"
        $sheetsXmlFragment += "<sheet name='$sheetName' sheetId='$($sheetIndex + 1)' r:id='$rId'/>"
    }
    $WorkbookUri = [Uri]"/xl/workbook.xml"
    $WorkbookPart = $Package.CreatePart($WorkbookUri, "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet.main+xml")
    $WorkbookXml = [xml]"<?xml version='1.0' encoding='UTF-8' standalone='yes'?><workbook xmlns='$Namespace' xmlns:r='$RelNamespace'><sheets>$sheetsXmlFragment</sheets></workbook>"
    $WorkbookXml.Save($WorkbookPart.GetStream([System.IO.FileMode]::Create, [System.IO.FileAccess]::Write))
    $Package.CreateRelationship($WorkbookUri, [System.IO.Packaging.TargetMode]::Internal, "http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument", "rId1") | Out-Null
    # Styles part with normal (Calibri 11) and header (Calibri 12 bold) fonts
    $StylesUri = [Uri]"/xl/styles.xml"
    $StylesPart = $Package.CreatePart($StylesUri, "application/vnd.openxmlformats-officedocument.spreadsheetml.styles+xml")
    $StylesXml = [xml]@"
<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<styleSheet xmlns="$Namespace">
    <fonts count="2">
        <font><sz val="11"/><name val="Calibri"/><family val="2"/></font>
        <font><b/><sz val="12"/><name val="Calibri"/><family val="2"/></font>
    </fonts>
    <fills count="2">
        <fill><patternFill patternType="none"/></fill>
        <fill><patternFill patternType="gray125"/></fill>
    </fills>
    <borders count="1">
        <border><left/><right/><top/><bottom/><diagonal/></border>
    </borders>
    <cellStyleXfs count="1">
        <xf numFmtId="0" fontId="0" fillId="0" borderId="0"/>
    </cellStyleXfs>
    <cellXfs count="2">
        <xf numFmtId="0" fontId="0" fillId="0" borderId="0" xfId="0"/>
        <xf numFmtId="0" fontId="1" fillId="0" borderId="0" xfId="0" applyFont="1"/>
    </cellXfs>
    <cellStyles count="1">
        <cellStyle name="Normal" xfId="0" builtinId="0"/>
    </cellStyles>
</styleSheet>
"@
    $StylesXml.Save($StylesPart.GetStream([System.IO.FileMode]::Create, [System.IO.FileAccess]::Write))
    # Create each sheet part
    $sheetUris = @()
    for ($sheetIndex = 0; $sheetIndex -lt $Sheets.Count; $sheetIndex++) {
        $sheetData = $Sheets[$sheetIndex].Data
        $sheetColumns = $Sheets[$sheetIndex].Columns
        # Auto-detect columns if not provided
        if (-not $sheetColumns -and $sheetData.Count -gt 0) {
            $sheetColumns = if ($sheetData[0] -is [System.Management.Automation.PSObject]) {
                ($sheetData[0] | Get-Member -MemberType NoteProperty,Property | Select-Object -ExpandProperty Name)
            } else { @("Value") }
        }
        # Measure column widths (headers with bold font, data with regular font)
        $columnMaxWidths = @{}
        for ($i = 0; $i -lt $sheetColumns.Count; $i++) {
            $columnMaxWidths[$i] = (& $MeasureText $sheetColumns[$i] $measureFontHeader)
        }
        foreach ($RowData in $sheetData) {
            for ($i = 0; $i -lt $sheetColumns.Count; $i++) {
                $Header = $sheetColumns[$i]
                $CellValue = if ($RowData -is [System.Management.Automation.PSObject]) {
                    ($RowData | Select-Object -ExpandProperty $Header -ErrorAction SilentlyContinue)
                } else { $RowData[$i] }
                $measuredWidth = (& $MeasureText "$CellValue" $measureFont)
                if ($measuredWidth -gt $columnMaxWidths[$i]) {
                    $columnMaxWidths[$i] = $measuredWidth
                }
            }
        }
        # Build sheet XML with frozen first row
        $SheetUri = [Uri]"/xl/worksheets/sheet$($sheetIndex + 1).xml"
        $sheetUris += $SheetUri
        $SheetPart = $Package.CreatePart($SheetUri, "application/vnd.openxmlformats-officedocument.spreadsheetml.worksheet+xml")
        $isFirstSheet = ($sheetIndex -eq 0)
        $tabSelected = if ($isFirstSheet) { "1" } else { "0" }
        $SheetXml = [xml]"<?xml version='1.0' encoding='UTF-8' standalone='yes'?><worksheet xmlns='$Namespace' xmlns:r='$RelNamespace'><sheetViews><sheetView tabSelected='$tabSelected' workbookViewId='0'><pane ySplit='1' topLeftCell='A2' activePane='bottomLeft' state='frozen'/><selection pane='bottomLeft' activeCell='A2' sqref='A2'/></sheetView></sheetViews><cols/><sheetData/></worksheet>"
        $NamespaceManager = New-Object System.Xml.XmlNamespaceManager($SheetXml.NameTable)
        $NamespaceManager.AddNamespace("x", $Namespace)
        # Column widths
        $ColsNode = $SheetXml.SelectSingleNode("//x:cols", $NamespaceManager)
        for ($i = 0; $i -lt $sheetColumns.Count; $i++) {
            $ColElement = $SheetXml.CreateElement("col", $Namespace)
            $colNumber = $i + 1
            $ColElement.SetAttribute("min", [string]$colNumber)
            $ColElement.SetAttribute("max", [string]$colNumber)
            # Measured width + 2 character units padding for cell margins, clamped to Excel max of 255
            $calculatedWidth = [math]::Round($columnMaxWidths[$i] + 2, 2)
            $calculatedWidth = [math]::Max(8, [math]::Min($calculatedWidth, 255))
            $ColElement.SetAttribute("width", $calculatedWidth.ToString([System.Globalization.CultureInfo]::InvariantCulture))
            $ColElement.SetAttribute("bestFit", "1")
            $ColElement.SetAttribute("customWidth", "1")
            $ColsNode.AppendChild($ColElement) | Out-Null
        }
        # Header row (style index 1 = bold Calibri 12)
        $SheetDataNode = $SheetXml.SelectSingleNode("//x:sheetData", $NamespaceManager)
        $RowIndex = 1
        $HeaderRow = $SheetXml.CreateElement("row", $Namespace)
        $HeaderRow.SetAttribute("r", [string]$RowIndex)
        $SheetDataNode.AppendChild($HeaderRow) | Out-Null
        $ColIndex = 1
        $sheetColumns | ForEach-Object { & $AddCell $SheetXml $HeaderRow $Namespace $ColIndex $RowIndex $_ 1; $ColIndex++ }
        $RowIndex++
        # Data rows (default style index 0 = regular Calibri 11)
        $totalRows = $sheetData.Count
        $progressIncrement = if ($totalRows -gt 0) { 100 / $totalRows } else { 0 }
        $currentProgress = 0
        foreach ($RowData in $sheetData) {
            $Row = $SheetXml.CreateElement("row", $Namespace)
            $Row.SetAttribute("r", [string]$RowIndex)
            $SheetDataNode.AppendChild($Row) | Out-Null
            for ($ColIndex = 1; $ColIndex -le $sheetColumns.Count; $ColIndex++) {
                $Header = $sheetColumns[$ColIndex - 1]
                $CellValue = if ($RowData -is [System.Management.Automation.PSObject]) {
                    ($RowData | Select-Object -ExpandProperty $Header -ErrorAction SilentlyContinue)
                } else { $RowData[$ColIndex - 1] }
                & $AddCell $SheetXml $Row $Namespace $ColIndex $RowIndex $CellValue
            }
            $RowIndex++
            if ($ProgressBar) {
                $currentProgress += $progressIncrement
                $ProgressBar.Value = [int][math]::Min($currentProgress, 100)
                [System.Windows.Forms.Application]::DoEvents()
            }
        }
        $SheetXml.Save($SheetPart.GetStream([System.IO.FileMode]::Create, [System.IO.FileAccess]::Write))
    }
    # Workbook relationships : sheets + styles
    $WorkbookPartRef = $Package.GetPart($WorkbookUri)
    for ($sheetIndex = 0; $sheetIndex -lt $sheetUris.Count; $sheetIndex++) {
        $WorkbookPartRef.CreateRelationship($sheetUris[$sheetIndex], [System.IO.Packaging.TargetMode]::Internal, "http://schemas.openxmlformats.org/officeDocument/2006/relationships/worksheet", "rId$($sheetIndex + 1)") | Out-Null
    }
    $WorkbookPartRef.CreateRelationship($StylesUri, [System.IO.Packaging.TargetMode]::Internal, "http://schemas.openxmlformats.org/officeDocument/2006/relationships/styles", "rId$($Sheets.Count + 1)") | Out-Null
    $Package.Close()
    # Dispose GDI measurement objects
    $measureGraphics.Dispose()
    $measureBitmap.Dispose()
    $measureFontHeader.Dispose()
    $measureFont.Dispose()
}


